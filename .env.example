# =========================
# LLM Settings
# =========================
# 默认使用 DashScope OpenAI-compatible API
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-long

# 也可以换成其它 OpenAI-compatible API，例如：
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=your_openai_model_name


# =========================
# TTS Settings
# =========================
# 当前默认使用 Edge TTS
TTS_PROVIDER=edge

EDGE_TTS_VOICE=zh-CN-YunyangNeural
EDGE_TTS_RATE=+6%
EDGE_TTS_VOLUME=+0%

# 以下是预留给 DashScope CosyVoice 的配置，目前默认不使用
# TTS_PROVIDER=dashscope
# TTS_MODEL=cosyvoice-v1
# TTS_VOICE=longxiang