# =========================
# Secrets / API keys
# =========================
.env
.env.*
!.env.example

# =========================
# Python cache
# =========================
__pycache__/
*.py[cod]
*$py.class

# =========================
# Virtual environments
# =========================
.venv/
venv/
env/
paperbridge/

# =========================
# Python tool caches
# =========================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# =========================
# Generated outputs
# =========================
outputs/*
!outputs/.gitkeep

# =========================
# Input papers / private data
# =========================
input/*
!input/.gitkeep

# =========================
